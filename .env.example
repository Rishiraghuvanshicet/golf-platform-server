MONGO_URI=mongodb+srv://user:pass@cluster.example.net/dbname
JWT_SECRET=use-a-long-random-string-in-production

# Comma-separated, no trailing slash. Must match the browser Origin (e.g. your Vercel URL exactly).
# Local + production example:
CLIENT_ORIGIN=http://localhost:3000,https://your-app.vercel.app

# Currency units per active subscriber into the monthly base pool (PRD prize pool).
PRIZE_POOL_CONTRIBUTION_PER_SUB=100
